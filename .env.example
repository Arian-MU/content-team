# AI API Keys - all four required
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
DEEPSEEK_API_KEY=
VOYAGE_API_KEY=

# Local database paths
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION_NAME=linkedin_knowledge
SQLITE_DB_PATH=./data/content_agent.db

# Google Drive sync
GDRIVE_ENABLED=false
GDRIVE_FOLDER_ID=
GDRIVE_CREDENTIALS_PATH=./config/gdrive_credentials.json

# App config
LOG_LEVEL=INFO
MAX_RETRIES=1

# Test mode — set to true for cheap end-to-end runs (uses sonar + claude-haiku)
# Switch back to false for real content generation
TEST_MODE=false
